# ============================================================
# Creative Suite - .gitignore
# ============================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
release/
build/
out/

# Electron
*.asar
app-update.yml
electron-builder.yml

# Environment & Secrets
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.p12
*.pfx

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*
.Trash-*

# Editors & IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
*.swp
*.swo
*~
.atom/
.eslintcache

# Logs
logs/
*.log

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp
*.temp
.cache/

# Compiled source
*.com
*.class
*.dll
*.exe
*.o
*.so

# Archives
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# png
*.png

# Optional: Uncomment if you want to ignore source maps in dev
# *.js.map
# *.css.map
